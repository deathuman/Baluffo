{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve static site (8080)",
      "type": "shell",
      "command": "python -m http.server 8080 --directory .",
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Serving HTTP on"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Stop static site",
      "type": "shell",
      "command": "Get-CimInstance Win32_Process | Where-Object { $_.Name -match 'python(\\.exe)?' -and $_.CommandLine -match 'http\\.server 8080' } | ForEach-Object { Stop-Process -Id $_.ProcessId -Force }",
      "problemMatcher": []
    },
    {
      "label": "Serve admin check site (8765)",
